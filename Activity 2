<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Button Recreation</title>
<style>
    body {
        background: #000;
        color: white;
        font-family: Arial, sans-serif;
        text-align: center;
        padding: 40px;
    }

    .container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        justify-items: center;
    }

    .section {
        background: #111;
        padding: 20px;
        border-radius: 10px;
        width: 250px;
    }

    /* Uber */
    .uber-btn {
        background: black;
        color: white;
        border: 4px solid #ddd;
        padding: 12px 25px;
        font-size: 16px;
        cursor: pointer;
    }

    /* Amazon */
    .amazon-btn {
        background: rgb(255, 216, 20);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-size: 16px;
        cursor: pointer;
    }

    /* GitHub */
    .github-btn {
        background: rgb(46, 164, 79);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 6px;
        font-size: 16px;
        cursor: pointer;
    }

    /* Bootstrap */
    .bootstrap-primary {
        background: rgb(121, 82, 179);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        margin-right: 10px;
        cursor: pointer;
    }

    .bootstrap-secondary {
        background: rgb(108, 117, 125);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

    /* LinkedIn */
    .linkedin-main {
        background: rgb(10, 102, 194);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 25px;
        margin-right: 10px;
        cursor: pointer;
    }

    .linkedin-save {
        background: transparent;
        color: rgb(10, 102, 194);
        border: 2px solid rgb(10, 102, 194);
        padding: 10px 20px;
        border-radius: 25px;
        cursor: pointer;
    }

    /* Watermark */
    .watermark {
        position: fixed;
        bottom: 10px;
        right: 15px;
        font-size: 14px;
        color: rgba(255,255,255,0.3);
    }
</style>
</head>

<body>

<h1>Button Recreation</h1>

<div class="container">

    <div class="section">
        <h3>2a. Uber</h3>
        <button class="uber-btn">Request now</button>
    </div>

    <div class="section">
        <h3>2b. Amazon</h3>
        <button class="amazon-btn">Add to Cart</button>
    </div>

    <div class="section">
        <h3>2c. GitHub</h3>
        <button class="github-btn">Sign up</button>
    </div>

    <div class="section">
        <h3>2d. Bootstrap</h3>
        <button class="bootstrap-primary">Get started</button>
        <button class="bootstrap-secondary">Download</button>
    </div>

    <div class="section">
        <h3>2e. LinkedIn</h3>
        <button class="linkedin-main">Apply on company website</button>
        <button class="linkedin-save">Save</button>
    </div>

</div>

<div class="watermark">Jay</div>

</body>
</html>
